# Copy to config.env and edit. Consumed by the api and scanner via envFrom.
# config.env is gitignored — never commit real values.

# Filesystem root of the data tree the scanner walks and the API reads.
# MUST match the mountPath of the catalog-data volume in k8s/base/api.yaml and
# k8s/base/scanner.yaml. If you change one, change all three.
CATALOG_DATA_ROOT=/groups/cryoet/cryoet/data/scratch/data

# SQLite catalog DB. The path points at the catalog-db volume (mounted at /db).
CATALOG_DB_URL=sqlite:////db/cryoet_catalog.db

# Directory of pre-generated thumbnail PNGs (the thumbnails volume, mounted at
# /thumbnails). The API refuses to start if this does not exist.
CATALOG_THUMBNAIL_DIR=/thumbnails

# Browser origins the API accepts (comma-separated). Must include the public
# URL of the portal.
CORS_ORIGINS=https://ai-cryoet.int.janelia.org

# Port the in-process Neuroglancer server binds inside the API container. nginx
# proxies the Neuroglancer root paths here. Changing this requires updating the
# neuroglancer upstream in k8s/base/nginx.yaml to match.
NEUROGLANCER_PORT=8050

# Bounded LRU size for concurrently active Neuroglancer viewers (optional).
# NEUROGLANCER_MAX_VIEWERS=8

# Override the hostname in Neuroglancer viewer URLs (optional). Not required for
# the single-route deployment: the frontend re-roots viewer URLs onto the page
# origin and nginx proxies the Neuroglancer paths, so the host the API reports
# is discarded.
# DASHBOARD_HOSTNAME=ai-cryoet.int.janelia.org
