    "TiltSeries": {
      "additionalProperties": true,
      "description": "One tilt series within an acquisition (composite-PK child of Acquisition).\n\nComposite primary key: ``(sample_id, acquisition_id, tilt_series_id)``.\n``tilt_series_id`` is the MDOC stem (with collision-disambiguating suffix\nwhen needed; see plan \u00a711.23). Powers the per-tilt-series UI cards\n(polar plot + median-tilt preview + Neuroglancer launch). All non-PK\nfields are optional so a tilt series can be ingested before MDOC parse\nsucceeds.",
      "properties": {
        "sample_id": {
          "title": "Sample Id",
          "type": "string"
        },
        "acquisition_id": {
          "title": "Acquisition Id",
          "type": "string"
        },
        "tilt_series_id": {
          "title": "Tilt Series Id",
          "type": "string"
        },
        "mdoc_path": {
          "title": "Mdoc Path",
          "type": "string"
        },
        "st_path": {
          "title": "St Path",
          "type": "string"
        },
        "zarr_path": {
          "title": "Zarr Path",
          "type": "string"
        },
        "n_tilts": {
          "title": "N Tilts",
          "type": "integer"
        },
        "tilt_range_min": {
          "title": "Tilt Range Min",
          "type": "number"
        },
        "tilt_range_max": {
          "title": "Tilt Range Max",
          "type": "number"
        },
        "tilt_axis_angle": {
          "title": "Tilt Axis Angle",
          "type": "number"
        },
        "voltage": {
          "title": "Voltage",
          "type": "number"
        },
        "pixel_spacing": {
          "title": "Pixel Spacing",
          "type": "number"
        },
        "image_format": {
          "title": "Image Format",
          "enum": [
            "EER",
            "TIFF",
            "MRC"
          ],
          "type": "string"
        },
        "microscope": {
          "title": "Microscope",
          "type": "string"
        },
        "camera": {
          "title": "Camera",
          "type": "string"
        },
        "tilt_angles": {
          "title": "Tilt Angles",
          "items": {
            "type": "number"
          },
          "type": "array"
        },
        "mtime": {
          "title": "Mtime",
          "type": "number"
        }
      },
      "title": "TiltSeries",
      "type": "object"
    }
