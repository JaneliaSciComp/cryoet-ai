# Copy to .env and fill in values for `docker compose`

# REQUIRED — path to the data tree the scanner walks and the API reads.
# Used as both the host-side bind-mount source and the in-container path the
# app reads via $CATALOG_DATA_ROOT. On Janelia hosts this is typically
# /groups/cryoet/cryoet/data/scratch/data.
CATALOG_DATA_ROOT=/groups/cryoet/cryoet/data/scratch/data

# CORS origins the API accepts for browser requests. For the nginx-fronted
# compose this is the public origin you hit in the browser. Multiple values
# can be comma-separated.
CORS_ORIGINS=http://localhost

# Host port nginx listens on
NGINX_PORT=80
